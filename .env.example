# Backend API URL (server-side, used by Next.js rewrites)
# Set this to your deployed server URL (e.g., https://cornerstone-server.vercel.app)
API_URL=http://localhost:5000

# Public API URL (client-side, used by browser)
# In dev, use direct URL (e.g., http://localhost:5000/api)
# In production, use '/api' to go through Next.js rewrites (no CORS issues)
NEXT_PUBLIC_API_URL=http://localhost:5000/api
